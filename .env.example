# Postware Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# =============================================================================
# TELEGRAM CONFIGURATION (Required)
# =============================================================================

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (numeric) - used for sender authorization
# Get your ID by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# =============================================================================
# LLM PROVIDER API KEYS
# Configure the key for your chosen provider in config.yaml
# Only one provider is active at a time, but you can set multiple keys
# =============================================================================

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI (GPT) - https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Groq (Llama, Mixtral) - https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Google (Gemini) - https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_key_here

# DeepSeek - https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_key_here

# Qwen (Alibaba) - https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=your_qwen_key_here

# Minimax - https://www.minimaxi.com/user-center/basic-information
MINIMAX_API_KEY=your_minimax_key_here

# Kimi (Moonshot) - https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=your_kimi_key_here

# Z.ai - https://z.ai/
Z_AI_API_KEY=your_zai_key_here

# =============================================================================
# LOCAL LLM CONFIGURATION (Optional)
# For Ollama, LM Studio, or custom endpoints
# No API key required - configure base_url in config.yaml instead
# =============================================================================
